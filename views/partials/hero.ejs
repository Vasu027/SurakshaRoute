<section class="hero">
  <div class="hero-inner container">
    <div class="hero-left">
      <h1 class="hero-title">
        Welcome to <span class="accent">SurakshaRoute</span>
      </h1>
      <p class="hero-sub">
        Your ultimate secure companion for safe, smart travel. Empowering you with real-time location mapping, nearby secure zones, dynamic companion check-ins, and instant SOS alerts.
      </p>
      <% if (!currentUser) { %>
        <div class="hero-ctas">
          <a href="/auth/signup" class="btn btn-primary">Get Started Now</a>
          <a href="/auth/login" class="btn btn-outline">Sign In</a>
        </div>
      <% } else { %>
        <a href="/dashboard" class="btn btn-primary">Go to Safety Dashboard</a>
      <% } %>
    </div>

    <div class="hero-right">
      <svg width="340" height="340" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="hero-illustration">
        <defs>
          <linearGradient id="shieldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#6366f1" />
            <stop offset="50%" stop-color="#a855f7" />
            <stop offset="100%" stop-color="#ec4899" />
          </linearGradient>
          <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
            <feGaussianBlur stdDeviation="8" result="blur" />
            <feComposite in="SourceGraphic" in2="blur" operator="over" />
          </filter>
        </defs>
        
        <!-- Outer glowing ring -->
        <circle cx="100" cy="100" r="85" stroke="url(#shieldGrad)" stroke-width="1.5" stroke-dasharray="10 6" opacity="0.3" />
        
        <!-- Inner ring -->
        <circle cx="100" cy="100" r="70" stroke="url(#shieldGrad)" stroke-width="1" opacity="0.15" />
        
        <!-- Glowing shield shape -->
        <path d="M100 45 C125 45, 145 35, 145 35 C145 75, 135 125, 100 155 C65 125, 55 75, 55 35 C55 35, 75 45, 100 45 Z" fill="url(#shieldGrad)" fill-opacity="0.1" stroke="url(#shieldGrad)" stroke-width="3" filter="url(#glow)" />
        
        <!-- Location marker inside shield -->
        <path d="M100 65 C88 65, 78 75, 78 88 C78 105, 100 130, 100 130 C100 130, 122 105, 122 88 C122 75, 112 65, 100 65 Z" fill="url(#shieldGrad)" fill-opacity="0.8" />
        <circle cx="100" cy="88" r="7" fill="#0a0f1d" />
      </svg>
    </div>
  </div>
</section>
